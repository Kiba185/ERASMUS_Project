generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  urgency     Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SchoolInfo {
  id             Int    @id @default(1) // Singleton pattern
  schoolName     String @default("John Amos Comenius Grammar School")
  registrationId String @default("12345678")
  principal      String @default("John Doe, M.A.")
  street         String @default("School Street 123")
  city           String @default("Prague 1")
  zipCode        String @default("110 00")
  email          String @default("office@gjak.cz")
  phone          String @default("+420 123 456 789")
  website        String @default("https://www.gjak.cz")
}

model Semester {
  id        Int      @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
}

model User {
  id        Int      @id @default(autoincrement())
  role      String
  lastName  String
  firstName String
  birthday  DateTime
  createdAt DateTime @default(now())
  username  String
  password  String
  email     String
  phone     String
  adress    String

  classes    Class[]
  timeTables TimeTable[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  parentId Int?
  parent   User?  @relation("ParentChild", fields: [parentId], references: [id])
  children User[] @relation("ParentChild")

  events   Event[]
  subjects Subject[]
  groups   Group[]  @relation("GroupStudents")

  attendances  Attendance[]  @relation("StudentAttendance")
  absenceNotes AbsenceNote[] @relation("StudentAbsenceNotes")

  taughtClass Class? @relation("ClassTeacher")
}

model Subject {
  id           Int           @id @default(autoincrement())
  name         String
  code         String
  color        String
  timeTables   TimeTable[]
  teachers     User[]
  attendances  Attendance[]  @relation("AttendanceSubject")
  lessonTopics LessonTopic[] @relation("LessonTopicSubject")
}

model Lesson {
  id        Int    @id @default(autoincrement())
  teacherId Int
  classId   Int
  subjectId Int
  name      String
  classroom String
}

model GradeColumn {
  id        Int      @id @default(autoincrement())
  subjectId Int
  TeacherId Int
  name      String
  weight    Int
  date      DateTime
  classId   Int      @default(1)
}

model Grade {
  id        Int     @id @default(autoincrement())
  gColumnId Int
  userId    Int
  grade     Decimal
}

model Attendance {
  id            Int           @id @default(autoincrement())
  date          DateTime
  studentId     Int
  student       User          @relation("StudentAttendance", fields: [studentId], references: [id])
  subjectId     Int
  subject       Subject       @relation("AttendanceSubject", fields: [subjectId], references: [id])
  classId       Int
  class         Class         @relation("AttendanceClass", fields: [classId], references: [id])
  periodNumber  Int           @default(0)
  status        String
  absenceType   String?
  absenceReason String?
  createdAt     DateTime      @default(now())
  absenceNotes  AbsenceNote[]

  @@unique([date, studentId, subjectId, periodNumber])
}

model LessonTopic {
  id           Int      @id @default(autoincrement())
  date         DateTime
  classId      Int
  class        Class    @relation("LessonTopicClass", fields: [classId], references: [id])
  subjectId    Int
  subject      Subject  @relation("LessonTopicSubject", fields: [subjectId], references: [id])
  periodNumber Int      @default(0)
  topic        String
  createdAt    DateTime @default(now())

  @@unique([date, classId, subjectId, periodNumber])
}

model AbsenceNote {
  id           Int        @id @default(autoincrement())
  studentId    Int
  student      User       @relation("StudentAbsenceNotes", fields: [studentId], references: [id])
  attendanceId Int?       @unique
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
  startDate    DateTime?
  endDate      DateTime?
  startPeriod  Int?
  endPeriod    Int?
  reason       String
  status       String     @default("sent")
  createdAt    DateTime   @default(now())
}

model Room {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  timeTables TimeTable[]
}

model Class {
  id           Int           @id @default(autoincrement())
  name         String
  students     User[]
  timeTables   TimeTable[]
  events       Event[]
  attendances  Attendance[]  @relation("AttendanceClass")
  lessonTopics LessonTopic[] @relation("LessonTopicClass")
  groups       Group[]

  classTeacherId Int?  @unique
  classTeacher   User? @relation("ClassTeacher", fields: [classTeacherId], references: [id])
}

model TimeTable {
  id            Int     @id @default(autoincrement())
  day           String
  week          String
  startTime     String
  endTime       String
  periodNumber  Int
  roomId        Int
  room          Room    @relation(fields: [roomId], references: [id])
  group         String  @default("Whole Class")
  isPermanent   Boolean @default(true)
  exceptionDate String?
  status        String  @default("active")
  templateId    Int?

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId Int
  teacher   User @relation(fields: [teacherId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])
}

model Event {
  id                      Int      @id @default(autoincrement())
  participantsIndividuals User[]
  participantsClasses     Class[]
  title                   String
  description             String
  startDate               DateTime
  endDate                 DateTime
  type                    String
  startTime               DateTime
  allDay                  Boolean
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int
  recipientId Int
  body        String
  subject     String   @default("")
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)

  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id])
}

model Group {
  id       Int    @id @default(autoincrement())
  name     String
  classId  Int
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  students User[] @relation("GroupStudents")
}

model Period {
  id           Int      @id @default(autoincrement())
  periodNumber Int      @unique
  startTime    String
  endTime      String
  createdAt    DateTime @default(now())
}
