// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  urgency     Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  role      String
  lastName  String
  firstName String
  birthday  DateTime
  createdAt DateTime @default(now())
  username  String
  password  String
  email     String
  phone     String
  adress    String

  classes    Class[]
  timeTables TimeTable[]

  // Parent-child relationship
  parentId Int?
  parent   User?  @relation("ParentChild", fields: [parentId], references: [id])
  children User[] @relation("ParentChild")

  // Other relations
  events Event[]
}

model Subject {
  id         Int         @id @default(autoincrement())
  name       String
  code       String
  color      String
  timeTables TimeTable[]
}

model Lesson {
  id        Int    @id @default(autoincrement())
  teacherId Int
  classId   Int
  subjectId Int
  name      String
  classroom String
}

model GradeColumn {
  id        Int      @id @default(autoincrement())
  subjectId Int
  TeacherId Int
  name      String
  weight    Int
  date      DateTime
}

model Grade {
  id        Int     @id @default(autoincrement())
  gColumnId Int
  userId    Int
  grade     Decimal
}

model Class {
  id         Int         @id @default(autoincrement())
  name       String
  students   User[]
  timeTables TimeTable[]

  events Event[]
}

model TimeTable {
  id           Int    @id @default(autoincrement())
  day          String
  startTime    String
  endTime      String
  periodNumber Int
  room         String

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId Int
  teacher   User @relation(fields: [teacherId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])
}

model Event {
  id                      Int      @id @default(autoincrement())
  participantsIndividuals User[]
  participantsClasses     Class[]
  title                   String
  description             String
  startDate               DateTime
  endDate                 DateTime
  type                    String
  startTime               DateTime
  allDay                  Boolean
}
