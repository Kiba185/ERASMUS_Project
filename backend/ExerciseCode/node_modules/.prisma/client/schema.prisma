// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  urgency     Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  role      String
  lastName  String
  firstName String
  birthday  DateTime
  createdAt DateTime @default(now())
  username  String
  password  String
  email     String
  phone     String
  adress    String

  classes    Class[]
  timeTables TimeTable[]
}

model Subject {
  id         Int         @id @default(autoincrement())
  name       String
  code       String
  color      String
  timeTables TimeTable[]
}

model Lesson {
  id        Int    @id @default(autoincrement())
  teacherId Int
  classId   Int
  subjectId Int
  name      String
  classroom String
}

model GradeColumn {
  id        Int      @id @default(autoincrement())
  subjectId Int
  TeacherId Int
  name      String
  weight    Int
  date      DateTime
}

model Grade {
  id        Int @id @default(autoincrement())
  gColumnId Int
  userId    Int
  grade     Int
}

model Class {
  id         Int         @id @default(autoincrement())
  name       String
  students   User[]
  timeTables TimeTable[] // 👈 OPRAVENO: Zpětná vazba pro rozvrh
}

model TimeTable {
  id           Int    @id @default(autoincrement())
  day          String
  startTime    String
  endTime      String
  periodNumber Int
  room         String

  // 👈 OPRAVENO: Tady jsou konečně vysvětlené vztahy pro tvůj backend!
  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId Int
  teacher   User @relation(fields: [teacherId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])
}
